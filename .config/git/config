[init]
  defaultBranch = main

[core]
  excludesfile = ~/.config/git/.gitignore
  pager = less -iXFR

[color]
  ui = true

[user]
  email = tyriis@users.noreply.github.com
  name = Nils Müller
  signingkey = ~/.ssh/id_ed25519_sk.pub

[alias]
  co = checkout
  st = status
  hist = "log --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short"
  logo = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ (%cn)" --decorate
  undo = reset HEAD~
  yolo = !git add -A && git commit -m \"$(curl -s https://whatthecommit.com/index.txt)\"
  broom = "!git fetch -p && git switch main && git pull && git branch -vv | grep ': gone]' | awk '{print $1}' | xargs -r git branch -D"

[commit]
  # show diff in commit editor window
  verbose = true
  gpgsign = true

[push]
  # commit resolveable tags on commit
  followTags = true
  # do not show The current branch ... has no upstream branch.
  default = current

[pull]
  rebase = false

[gpg]
  format = ssh

[gpg "ssh"]
  allowedSignersFile = ~/.config/git/allowed_signers

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

[credential "https://github.com"]
  helper = !/home/nils/.local/share/mise/shims/gh auth git-credential

[credential "https://gist.github.com"]
  helper = !/home/nils/.local/share/mise/shims/gh auth git-credential