{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@devtheops/opencode-plugin-otel",
    "opencode-mem",
    "@slkiser/opencode-quota",
    "opencode-skill-creator"
  ],
  "lsp": true,
  "small_model": "github-copilot/gpt-5-mini",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.config/gh/config.yml*": "ask",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.example": "allow",
      "*secret*": "ask"
    },
    "edit": "allow",
    "bash": {
      "*.config/gh/config.yml*": "ask",
      "*secret*": "ask",
      "gh pr list*": "allow",
      "gh pr diff*": "allow",
      "gh search prs*": "allow",
      "gh pr comment*": "ask",
      "gh pr view*": "allow",
      "gh release list*": "allow",
      "git add *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch *": "allow",
      "yamllint *": "allow",
      "kubectl config current-context*": "allow",
      "kubectl get secret*": "ask",
      "kubectl get pod*": "allow",
      "kubectl describe pod*": "allow",
      "kubectl logs*": "allow",
      "kubectl get helmreleases*": "allow",
      "*": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "task": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "lsp": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": "ask",
    "doom_loop": "ask"
  }
}