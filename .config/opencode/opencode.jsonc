{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@devtheops/opencode-plugin-otel",
    "opencode-mem",
    "@slkiser/opencode-quota",
    "opencode-skill-creator"
  ],
  "lsp": true,
  "small_model": "github-copilot/gpt-5-mini",
  // "small_model": "llamacpp/qwen2.5-7b-instruct-q3_k_m.gguf",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.config/gh/config.yml*": "ask",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.example": "allow",
      "*secret*": "ask",
      "documents/obsidian*": "allow"
    },
    "edit": "allow",
    "bash": {
      "*.config/gh/config.yml*": "ask",
      "*secret*": "ask",
      "gh pr list*": "allow",
      "gh pr diff*": "allow",
      "gh search prs*": "allow",
      "gh pr comment*": "ask",
      "gh pr view*": "allow",
      "gh release list*": "allow",
      "git add *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch *": "allow",
      "yamllint *": "allow",
      "kubectl config current-context*": "allow",
      "kubectl get secret*": "ask",
      "kubectl get pod*": "allow",
      "kubectl describe pod*": "allow",
      "kubectl logs*": "allow",
      "kubectl get helmreleases*": "allow",
      "*": "allow",
      "sudo *": "deny",
      "sudo*": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "task": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "lsp": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Llama.cpp Local Server",
      "options": {
        "baseURL": "http://localhost:8085/v1"
      },
      "models": {
        "qwen2.5-7b-instruct-q3_k_m.gguf": {
          "name": "Qwen 2.5 VL 7b (local)"
        }
      }
    }
  }
}
